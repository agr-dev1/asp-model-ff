      <p class="page-subtitle">A look back at previous seasons: the good, the bad, and the cursed.</p>
    </div>
    <hr class="divider" />
 
    <div class="accordion-list" id="accordionList">
 
      <!-- ── SEASON ENTRY — duplicate this block to add more ── -->
      <!--
        badge classes:
          badge-win  = champion / great finish
