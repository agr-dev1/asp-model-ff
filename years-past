    <button class="hamburger" id="hamburger" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </nav>
 
  <!-- Mobile Nav -->
  <div class="mobile-nav" id="mobileNav">
    <a href="https://www.aspfantasyfootball.com/index.html">Overall</a>
    <a href="https://www.aspfantasyfootball.com/qb.html">QB</a>
    <a href="https://www.aspfantasyfootball.com/rb.html">RB</a>
