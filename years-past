<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Past Seasons - ASP Model FF</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Exo+2:wght@400;600;700&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    /* ── Base / Reset ─────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
    :root {
      --bg:           #0d1117;
      --surface:      #161b22;
      --surface2:     #1c2230;
      --border:       #30363d;
      --accent:       #58a6ff;
      --accent-dim:   #1f6feb33;
      --text:         #e6edf3;
      --text-muted:   #8b949e;
      --green:        #3fb950;
      --radius:       8px;
      --nav-height:   56px;
    }
 
    html { scroll-behavior: smooth; }
 
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Roboto', sans-serif;
      font-size: 15px;
      line-height: 1.6;
      min-height: 100vh;
    }
 
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
 
    /* ── Nav ──────────────────────────────────────────────── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      height: var(--nav-height);
      display: flex;
      align-items: center;
      padding: 0 20px;
      gap: 6px;
      overflow-x: auto;
      white-space: nowrap;
    }
 
    .nav-brand {
      font-family: 'Exo 2', sans-serif;
      font-weight: 700;
      font-size: 17px;
      color: var(--text);
      margin-right: 10px;
      flex-shrink: 0;
    }
    .nav-brand:hover { text-decoration: none; color: var(--accent); }
 
    nav a.nav-link {
      color: var(--text-muted);
      font-size: 13px;
      font-weight: 500;
      padding: 5px 10px;
      border-radius: 6px;
      transition: background 0.15s, color 0.15s;
      flex-shrink: 0;
    }
    nav a.nav-link:hover { background: var(--accent-dim); color: var(--accent); text-decoration: none; }
    nav a.nav-link.active { color: var(--accent); background: var(--accent-dim); }
 
    /* ── Mobile hamburger nav ─────────────────────────────── */
    .hamburger {
      display: none;
      flex-direction: column;
      gap: 4px;
      cursor: pointer;
      padding: 6px;
      margin-left: auto;
      background: none;
      border: none;
    }
    .hamburger span {
      display: block;
      width: 22px;
      height: 2px;
      background: var(--text-muted);
      border-radius: 2px;
      transition: all 0.2s;
    }
 
    .mobile-nav {
      display: none;
      flex-direction: column;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 8px 0;
    }
    .mobile-nav.open { display: flex; }
    .mobile-nav a {
      color: var(--text-muted);
      padding: 10px 20px;
      font-size: 14px;
      font-weight: 500;
    }
    .mobile-nav a:hover { color: var(--accent); background: var(--accent-dim); text-decoration: none; }
    .mobile-nav a.active { color: var(--accent); }
 
    @media (max-width: 820px) {
      .nav-links { display: none; }
      .hamburger { display: flex; }
    }
    @media (min-width: 821px) {
      .mobile-nav { display: none !important; }
    }
 
    /* ── Page layout ──────────────────────────────────────── */
    .season-tag {
      text-align: center;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-muted);
      padding: 10px 0 0;
    }
 
    .page-container {
      max-width: 860px;
      margin: 0 auto;
      padding: 36px 20px 80px;
    }
 
    .page-header {
      margin-bottom: 12px;
    }
 
    .page-header h1 {
      font-family: 'Exo 2', sans-serif;
      font-size: clamp(26px, 5vw, 36px);
      font-weight: 700;
      color: var(--text);
      line-height: 1.2;
    }
 
    .page-subtitle {
      margin-top: 8px;
      color: var(--text-muted);
      font-size: 14px;
    }
 
    .divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 20px 0 32px;
    }
 
    /* ── Accordion ────────────────────────────────────────── */
    .accordion-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
 
    .accordion-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      transition: border-color 0.2s;
    }
    .accordion-item:hover { border-color: #484f58; }
    .accordion-item.open { border-color: var(--accent); }
 
    .accordion-trigger {
      width: 100%;
      background: none;
      border: none;
      cursor: pointer;
      padding: 18px 20px;
      display: flex;
      align-items: flex-start;
      gap: 14px;
      text-align: left;
    }
 
    .accordion-chevron {
      flex-shrink: 0;
      margin-top: 3px;
      width: 18px;
      height: 18px;
      color: var(--text-muted);
      transition: transform 0.25s ease, color 0.2s;
    }
    .accordion-item.open .accordion-chevron {
      transform: rotate(90deg);
      color: var(--accent);
    }
 
    .accordion-header-text { flex: 1; }
 
    .accordion-year {
      font-family: 'Exo 2', sans-serif;
      font-size: 18px;
      font-weight: 700;
      color: var(--text);
      display: block;
      line-height: 1.3;
    }
 
    .accordion-subtitle {
      margin-top: 3px;
      font-size: 13px;
      color: var(--text-muted);
      display: block;
    }
 
    /* Result badge */
    .result-badge {
      flex-shrink: 0;
      align-self: center;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.05em;
      padding: 4px 10px;
      border-radius: 20px;
      border: 1px solid transparent;
    }
    .badge-win  { background: #1a3a1f; color: var(--green); border-color: #2a5a2f; }
    .badge-mid  { background: #1f2a3a; color: var(--accent); border-color: #2a3f5a; }
    .badge-loss { background: #3a1a1a; color: #f85149; border-color: #5a2a2a; }
 
    .accordion-body {
      display: none;
      padding: 0 20px 22px 52px;
      color: var(--text);
      font-size: 14.5px;
      line-height: 1.75;
      border-top: 1px solid var(--border);
    }
    .accordion-body.open {
      display: block;
      animation: fadeSlide 0.2s ease;
    }
 
    @keyframes fadeSlide {
      from { opacity: 0; transform: translateY(-6px); }
      to   { opacity: 1; transform: translateY(0); }
    }
 
    .accordion-body p { margin-top: 14px; }
    .accordion-body p:first-child { margin-top: 14px; }
 
    .accordion-body strong { color: var(--accent); font-weight: 500; }
 
    .stat-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px 24px;
      margin-top: 16px;
      padding: 12px 16px;
      background: var(--surface2);
      border-radius: 6px;
      border: 1px solid var(--border);
      font-size: 13px;
    }
    .stat-item { color: var(--text-muted); }
    .stat-item span { color: var(--text); font-weight: 500; }
 
    /* ── Placeholder state ────────────────────────────────── */
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: var(--text-muted);
    }
    .empty-state .emoji { font-size: 40px; margin-bottom: 12px; }
    .empty-state p { font-size: 14px; }
  </style>
</head>
<body>
 
  <!-- Desktop Nav -->
  <nav>
